{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "mailclaw",
	"main": "src/index.ts",
	"compatibility_date": "2025-07-15",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "D1",
			"database_name": "mailclaw-d1",
			"database_id": "199c8d08-98a1-46af-a9e1-2c55f3582b87",
			"remote": true
		}
	],
	"workers_dev": true,
	"preview_urls": false,
	"placement": {
		"mode": "smart"
	}
}